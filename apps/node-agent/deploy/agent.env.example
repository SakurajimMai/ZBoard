# Required
TZ=Asia/Shanghai
ZBOARD_AGENT_API_BASE_URL=https://control.example.com
ZBOARD_AGENT_NODE_ID=1
ZBOARD_AGENT_NODE_SECRET=replace-with-plaintext-secret-from-node-create

# Optional (these are the defaults)
ZBOARD_AGENT_HEARTBEAT_INTERVAL=30s
ZBOARD_AGENT_PULL_INTERVAL=10s
ZBOARD_AGENT_TRAFFIC_INTERVAL=60s
ZBOARD_AGENT_RUNTIME_BINARY=/usr/local/bin/xray
ZBOARD_AGENT_RUNTIME_TYPE=xray
ZBOARD_AGENT_CONFIG_FILE=/etc/zboard-agent/runtime.json
ZBOARD_AGENT_WORK_DIR=/var/lib/zboard-agent
ZBOARD_AGENT_VERSION=0.1.0

# Stats gRPC API exposed by Xray StatsService or sing-box with with_v2ray_api.
# Set empty to disable per-user traffic scraping.
# For hand-installed sing-box, set ZBOARD_AGENT_SINGBOX_V2RAY_API=1 only when
# the binary was built with with_v2ray_api; otherwise the agent strips that
# config block before starting the runtime.
ZBOARD_AGENT_STATS_API_ADDR=127.0.0.1:10085
ZBOARD_AGENT_SINGBOX_V2RAY_API=0
