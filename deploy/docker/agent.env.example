# Zboard Node Agent 环境变量
# 复制此文件为 agent.env 并填入实际值

# 控制面地址（必须是 Agent 能访问到的地址）
ZBOARD_AGENT_API_BASE_URL=https://your-panel-domain.com

# 节点信息（创建节点时由控制面返回）
ZBOARD_AGENT_NODE_ID=1
ZBOARD_AGENT_NODE_SECRET=创建节点时返回的一次性密钥

# 运行时配置
ZBOARD_AGENT_RUNTIME_BINARY=/usr/local/bin/xray
ZBOARD_AGENT_RUNTIME_TYPE=xray
# 如果用 sing-box：
# ZBOARD_AGENT_RUNTIME_BINARY=/usr/local/bin/sing-box
# ZBOARD_AGENT_RUNTIME_TYPE=sing-box

# 流量统计 gRPC 地址（运行时自动监听）
ZBOARD_AGENT_STATS_API_ADDR=127.0.0.1:10085

# 可选调优
# ZBOARD_AGENT_HEARTBEAT_INTERVAL=30s
# ZBOARD_AGENT_PULL_INTERVAL=10s
# ZBOARD_AGENT_TRAFFIC_INTERVAL=60s
