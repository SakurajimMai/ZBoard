# Zboard API Server 环境变量
# 复制为 api.env 并填入实际值

# 服务监听
ZBOARD_HOST=0.0.0.0
ZBOARD_PORT=3000
TZ=Asia/Shanghai

# 数据库
ZBOARD_DB_DIALECT=mysql
ZBOARD_DB_DSN=user:password@tcp(db-host:3306)/zboard?parseTime=true&charset=utf8mb4

# 初始管理员（首次启动时自动创建，之后可删除这三行）
ZBOARD_ADMIN_SETUP_TOKEN=替换为随机字符串
ZBOARD_ADMIN_EMAIL=admin@example.com
ZBOARD_ADMIN_PASSWORD=替换为强密码

# 会话签名密钥（随机生成，如: openssl rand -hex 32）
ZBOARD_TOKEN_SECRET=替换为随机字符串

# CORS 允许的前端域名（逗号分隔，支持多个；设为 * 允许所有）
# 正式环境请改成用户浏览器访问前端时看到的地址，例如 http://your-server-ip:3001
ZBOARD_CORS_ORIGINS=http://localhost:3001
