# Zboard API Server 环境变量
# 复制此文件为 api.env 并填入实际值

# 服务监听
ZBOARD_HOST=0.0.0.0
ZBOARD_PORT=3000

# 数据库（三选一：mysql / postgres / sqlite）
ZBOARD_DB_DIALECT=mysql
ZBOARD_DB_DSN=user:password@tcp(your-db-host:3306)/zboard?parseTime=true&charset=utf8mb4

# 管理员初始化（首次 bootstrap 后即失效）
ZBOARD_ADMIN_SETUP_TOKEN=替换为随机字符串

# 会话签名密钥
ZBOARD_TOKEN_SECRET=替换为随机字符串

# ===== 支付渠道（可选，不配置则不启用）=====

# 易支付 (EasyPay)
# ZBOARD_EPAY_API_URL=https://pay.example.com
# ZBOARD_EPAY_PID=你的商户ID
# ZBOARD_EPAY_KEY=你的密钥

# Creem（海外信用卡/Apple Pay/Google Pay）
# ZBOARD_CREEM_API_KEY=creem_api_key
# ZBOARD_CREEM_WEBHOOK_SECRET=creem_webhook_secret
# ZBOARD_CREEM_API_URL=https://api.creem.io

# NOWPayments（加密货币 BTC/ETH/USDT）
# ZBOARD_NOWPAY_API_KEY=nowpayments_api_key
# ZBOARD_NOWPAY_IPN_SECRET=nowpayments_ipn_secret
# ZBOARD_NOWPAY_API_URL=https://api.nowpayments.io
