ZBOARD_HOST=0.0.0.0
ZBOARD_PORT=3000

# Choose one: mysql | postgres | sqlite
ZBOARD_DB_DIALECT=mysql

# DSN format depends on dialect:
#   mysql:    user:pass@tcp(host:3306)/db?parseTime=true&charset=utf8mb4
#   postgres: postgres://user:pass@host:5432/db?sslmode=require
#   sqlite:   file path; if empty, falls back to ZBOARD_DB_PATH below
ZBOARD_DB_DSN=user:pass@tcp(host:3306)/zboard?parseTime=true&charset=utf8mb4

# Only used when ZBOARD_DB_DIALECT=sqlite and ZBOARD_DB_DSN is empty
ZBOARD_DB_PATH=/data/zboard.sqlite

ZBOARD_ADMIN_SETUP_TOKEN=replace-with-one-time-setup-token
ZBOARD_TOKEN_SECRET=replace-with-random-token-secret
ZBOARD_BACKUP_DIR=/backups
